# Environment Configuration Example
# Copy this file to .env.develop, .env.test, or .env.prod and modify as needed

# Environment (develop/test/prod)
ENV=develop

# Debug mode
DEBUG=True

# Security Keys (IMPORTANT: Change these in production!)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database URL
# Development: sqlite:///./data/develop.db
# Test: sqlite:///./data/test.db
# Production: sqlite:///./data/prod.db
# Or use PostgreSQL: postgresql://user:password@localhost:5432/dbname
# Or use MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./data/develop.db

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
